# ============================================
# Petty Cash Manager — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env to version control.
# ============================================

# --- Database Container ---
POSTGRES_DB=pettycash
POSTGRES_USER=pettycash
POSTGRES_PASSWORD=changeme_in_production
DB_PORT=5432

# --- Database Backup Configuration ---
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# --- Backend Container ---
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/pettycash
SPRING_DATASOURCE_USERNAME=pettycash
SPRING_DATASOURCE_PASSWORD=changeme_in_production
CORS_ALLOWED_ORIGINS=http://localhost:3000
SERVER_PORT=8080
BACKEND_PORT=8080

# --- Frontend Container ---
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8080

# --- Authentication & JWT ---
DEMO_LOGIN_ENABLED=false
ALLOWED_DOMAIN=yourcompany.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
JWT_SECRET=your-jwt-secret-at-least-32-chars-long-for-hs256-signature
JWT_EXPIRATION_HOURS=8

# --- Google Drive (Receipt Auditing Uploads) ---
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-google-drive-folder-id
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_CLIENT_ID=100000000000000000000
GOOGLE_DRIVE_PRIVATE_KEY_ID=your-google-drive-private-key-id

# --- Transaction Custom Configuration ---
APP_COMPANIES=Freestone Infotech Pvt Ltd,Freestone Technologies LLP
TRANSACTION_EDIT_LIMIT_MONTHS=1
TRANSACTION_EDIT_LIMIT_DAYS=15

# --- Digital Signatures Configuration ---
APP_SIGNATURES_DIRECTORY=classpath:signatures/
APP_SIGNATURES_APPROVED_BY=admin@freestone.com


