<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-voucher-company-year-uniqueness" author="pettycash">
        <comment>Drop uq_transaction_voucher_date constraint to allow voucher number uniqueness by company and year via application validation</comment>

        <dropUniqueConstraint tableName="transactions" constraintName="uq_transaction_voucher_date"/>
    </changeSet>

</databaseChangeLog>
